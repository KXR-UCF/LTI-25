[Unit]
Description=Socket Server (Controller)
After=network.target

[Service]
Type=simple
User=lti
WorkingDirectory=/home/lti/
Restart=always
RestartSec=5
ExecStart=/bin/bash -c '/home/lti/venv/bin/python3 -u /home/lti/Wanda/Controls/controllerSocketServer.py >> /home/lti/Wanda/controls.log 2>&1'

[Install]
WantedBy=multi-user.target